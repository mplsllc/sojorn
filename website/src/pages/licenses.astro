          <tr class="border-b"><td class="py-2 px-3">PostgreSQL</td><td class="py-2 px-3">PostgreSQL License</td><td class="py-2 px-3">Database</td></tr>
          <tr class="border-b"><td class="py-2 px-3">PM2</td><td class="py-2 px-3">AGPL-3.0</td><td class="py-2 px-3">Node.js process manager</td></tr>
