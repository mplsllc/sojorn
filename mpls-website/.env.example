# SendPulse API Credentials
SENDPULSE_ID=your_sendpulse_client_id_here
SENDPULSE_SECRET=your_sendpulse_client_secret_here

# SendPulse Address Book
MPLS_ADDRESS_BOOK_ID=1
SOJORN_WAITLIST_ADDRESS_BOOK_ID=568090
SOJORN_WAITLIST_ADDRESS_BOOK_NAME=Sojorn Waitlist

# Transactional email sender (must be verified in SendPulse)
SOJORN_FROM_EMAIL=no-reply@sojorn.net
SOJORN_FROM_NAME=Sojorn

# Thank-you flow mode: automation (recommended), smtp, or none
SENDPULSE_THANK_YOU_MODE=automation
# Automation 360 event name (create this event in SendPulse)
SENDPULSE_A360_EVENT_NAME=sojorn_waitlist_signup
# Preferred: direct event webhook URL from SendPulse Events screen
SENDPULSE_A360_EVENT_URL=
# Optional: target a specific Automation 360 flow ID
SENDPULSE_A360_AUTOMATION_ID=

# ALTCHA proof-of-work (challenges served by Go backend at api.sojorn.net)
