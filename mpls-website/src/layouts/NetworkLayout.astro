---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'mp.ls | Digital Command Center' } = Astro.props;
const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en" class="h-full">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<meta name="description" content="mp.ls launchpad for the Patrick network." />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="MPLS LLC" />
		<link rel="manifest" href="/site.webmanifest" />
		<title>{title}</title>
		{isProd && (
			<>
				<script async src="https://www.googletagmanager.com/gtag/js?id=G-HXNPNL6C2G"></script>
				<script is:inline>
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', 'G-HXNPNL6C2G');
				</script>
			</>
		)}
	</head>
	<body class="min-h-screen antialiased">
		<!-- Main Content -->
		<main>
			<slot />
		</main>
	</body>
</html>
