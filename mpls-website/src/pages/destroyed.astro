---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Account Destroyed | Sojorn">
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-20">
    <div class="max-w-lg w-full text-center">
      <div class="w-20 h-20 bg-zinc-100 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      </div>

      <h1 class="text-4xl font-bold text-zinc-900 mb-4">Account Destroyed</h1>
      <p class="text-lg text-zinc-600 mb-8 leading-relaxed">
        Your account and all associated data have been permanently destroyed. This action cannot be undone.
      </p>

      <div class="bg-zinc-50 border border-zinc-200 rounded-xl p-6 mb-8 text-left space-y-3">
        <p class="text-sm text-zinc-500">The following has been permanently deleted:</p>
        <ul class="text-sm text-zinc-500 list-disc list-inside space-y-1">
          <li>Your profile and handle</li>
          <li>All posts, comments, and media</li>
          <li>All messages and encryption keys</li>
          <li>Followers and social connections</li>
        </ul>
      </div>

      <p class="text-sm text-zinc-400">
        Goodbye. &mdash; Sojorn
      </p>
    </div>
  </section>
</Layout>
