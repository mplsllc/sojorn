---
import NetworkLayout from '../layouts/NetworkLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.svelte';
---

<NetworkLayout title="Sojorn Beta | Request Access">

	<section class="relative h-[100svh] overflow-hidden bg-zinc-950 px-4 py-4 md:py-6">
		<div class="absolute inset-0 opacity-35">
			<div class="absolute -top-20 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-brand-600 blur-3xl"></div>
			<div class="absolute bottom-0 right-0 h-64 w-64 rounded-full bg-violet-600 blur-3xl"></div>
		</div>

		<div class="relative mx-auto flex h-full max-w-xl items-center">
			<div class="w-full overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-900 shadow-[0_0_0_1px_rgba(255,255,255,0.06),0_30px_90px_rgba(0,0,0,0.65)]">
				<img src="/img/sojorn-beta.png?v=20260215" alt="Sojorn Beta" class="max-h-[34svh] w-full object-cover" />

				<div class="border-t border-zinc-800 bg-white px-5 py-7 md:px-7 md:py-8">
					<p class="text-center text-xs font-semibold uppercase tracking-[0.22em] text-brand-700">Only One Next Step</p>
					<h1 class="mt-2 text-center text-3xl font-black text-zinc-900 md:text-4xl">Request Beta Access</h1>
					<p class="mt-2 text-center text-sm text-zinc-600">Enter your email. Get invited when access opens.</p>

					<div class="mt-4 grid grid-cols-3 gap-2 text-center">
						<div class="rounded-xl border border-zinc-200 bg-zinc-50 px-2 py-2">
							<p class="text-lg leading-none">🔐</p>
							<p class="mt-1 text-[10px] font-semibold uppercase tracking-wide text-zinc-700">E2EE Chat</p>
						</div>
						<div class="rounded-xl border border-zinc-200 bg-zinc-50 px-2 py-2">
							<p class="text-lg leading-none">🚫</p>
							<p class="mt-1 text-[10px] font-semibold uppercase tracking-wide text-zinc-700">No Tracking</p>
						</div>
						<div class="rounded-xl border border-zinc-200 bg-zinc-50 px-2 py-2">
							<p class="text-lg leading-none">🛡️</p>
							<p class="mt-1 text-[10px] font-semibold uppercase tracking-wide text-zinc-700">Data Sovereignty</p>
						</div>
					</div>

					<div class="mt-6 rounded-2xl border-2 border-brand-300 bg-brand-50 p-4 md:p-5">
						<NewsletterSignup client:load />
					</div>

					<div class="mt-3 flex items-center justify-center gap-4 text-xs font-medium text-zinc-500">
						<button type="button" data-legal-open="privacy" class="hover:text-zinc-700 underline underline-offset-2">Privacy Policy</button>
						<span aria-hidden="true">•</span>
						<button type="button" data-legal-open="terms" class="hover:text-zinc-700 underline underline-offset-2">Terms of Use</button>
					</div>
				</div>
			</div>
		</div>
	</section>

	<div id="legal-overlay" class="pointer-events-none fixed inset-0 z-50 bg-black/50 opacity-0 transition-opacity duration-300"></div>
	<aside id="legal-drawer" class="fixed right-0 top-0 z-50 flex h-[100svh] w-full translate-x-full flex-col border-l border-zinc-200 bg-white shadow-2xl transition-transform duration-300 sm:w-[440px]" aria-hidden="true">
		<div class="flex items-center justify-between border-b border-zinc-200 px-4 py-3">
			<div>
				<p id="legal-title" class="text-sm font-semibold text-zinc-900">Privacy Policy</p>
				<p class="text-xs text-zinc-500">Read without leaving this page</p>
			</div>
			<button id="legal-close" type="button" class="rounded-md border border-zinc-300 px-2 py-1 text-xs font-semibold text-zinc-700 hover:bg-zinc-100">Close</button>
		</div>

		<div class="flex items-center gap-2 border-b border-zinc-200 px-4 py-2">
			<button type="button" data-legal-tab="privacy" class="rounded-md bg-zinc-900 px-3 py-1.5 text-xs font-semibold text-white">Privacy</button>
			<button type="button" data-legal-tab="terms" class="rounded-md border border-zinc-300 px-3 py-1.5 text-xs font-semibold text-zinc-700">Terms</button>
		</div>

		<div class="min-h-0 flex-1">
			<iframe id="legal-frame" src="/privacy" title="Legal document viewer" class="h-full w-full border-0"></iframe>
		</div>
	</aside>

	<script is:inline>
		const legalDrawer = document.getElementById('legal-drawer');
		const legalOverlay = document.getElementById('legal-overlay');
		const legalFrame = document.getElementById('legal-frame');
		const legalTitle = document.getElementById('legal-title');
		const legalClose = document.getElementById('legal-close');
		const openButtons = document.querySelectorAll('[data-legal-open]');
		const tabButtons = document.querySelectorAll('[data-legal-tab]');

		const legalMap = {
			privacy: { href: '/privacy', title: 'Privacy Policy' },
			terms: { href: '/terms', title: 'Terms of Use' }
		};

		function setActiveTab(tab) {
			tabButtons.forEach((btn) => {
				const isActive = btn.getAttribute('data-legal-tab') === tab;
				btn.className = isActive
					? 'rounded-md bg-zinc-900 px-3 py-1.5 text-xs font-semibold text-white'
					: 'rounded-md border border-zinc-300 px-3 py-1.5 text-xs font-semibold text-zinc-700';
			});
		}

		function openLegal(tab) {
			const doc = legalMap[tab] || legalMap.privacy;
			if (legalFrame) legalFrame.src = doc.href;
			if (legalTitle) legalTitle.textContent = doc.title;
			setActiveTab(tab);

			if (legalDrawer) {
				legalDrawer.classList.remove('translate-x-full');
				legalDrawer.setAttribute('aria-hidden', 'false');
			}
			if (legalOverlay) {
				legalOverlay.classList.remove('pointer-events-none', 'opacity-0');
			}
		}

		function closeLegal() {
			if (legalDrawer) {
				legalDrawer.classList.add('translate-x-full');
				legalDrawer.setAttribute('aria-hidden', 'true');
			}
			if (legalOverlay) {
				legalOverlay.classList.add('pointer-events-none', 'opacity-0');
			}
		}

		openButtons.forEach((btn) => {
			btn.addEventListener('click', () => openLegal(btn.getAttribute('data-legal-open') || 'privacy'));
		});

		tabButtons.forEach((btn) => {
			btn.addEventListener('click', () => openLegal(btn.getAttribute('data-legal-tab') || 'privacy'));
		});

		if (legalClose) legalClose.addEventListener('click', closeLegal);
		if (legalOverlay) legalOverlay.addEventListener('click', closeLegal);

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') closeLegal();
		});
	</script>

</NetworkLayout>
