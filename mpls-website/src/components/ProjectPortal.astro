---
interface Props {
	title: string;
	url: string;
	techStack: string[];
	repoUrl?: string;
	summary?: string;
	accent?: 'sky' | 'mint' | 'amber' | 'rose';
	variant?: 'primary' | 'compact';
}

const { title, url, techStack, repoUrl, summary, accent = 'sky', variant = 'primary' } = Astro.props;

const accentMap: Record<NonNullable<Props['accent']>, string> = {
	sky: 'from-sky-200 via-sky-100 to-sky-50',
	mint: 'from-emerald-200 via-emerald-100 to-emerald-50',
	amber: 'from-amber-200 via-amber-100 to-amber-50',
	rose: 'from-rose-200 via-rose-100 to-rose-50',
};

const isPrimary = variant === 'primary';
---

<article
	class={`group relative flex min-w-0 flex-col rounded-2xl border border-[#d7d7cf] bg-[#f9f9f6] shadow-[0_8px_20px_rgba(15,23,42,0.06)] transition duration-200 hover:-translate-y-0.5 hover:border-[#c8c8c0] ${
		isPrimary ? 'gap-4 p-6' : 'gap-3 p-4'
	}`}
>
	<div class={`h-1 w-full rounded-full bg-gradient-to-r ${accentMap[accent]}`}></div>
	<div class={`flex min-w-0 flex-col ${isPrimary ? 'gap-4' : 'gap-3'} md:flex-row md:items-center`}>
		<div
			class={`relative w-full overflow-hidden rounded-xl border border-[#e1e1d8] bg-[#f3f3ee] ${
				isPrimary ? 'h-40 md:h-48 md:w-64' : 'h-24 md:h-28 md:w-44'
			}`}
		>
			<slot name="media">
				<div class="flex h-full items-center justify-center text-[10px] uppercase tracking-[0.4em] text-slate-500">
					No preview
				</div>
			</slot>
		</div>
		<div class={`flex min-w-0 flex-1 flex-col ${isPrimary ? 'gap-2' : 'gap-1.5'}`}>
			<div class="flex items-center justify-between gap-3">
				<h3 class={`font-semibold tracking-wide text-[#2a2a2a] break-words ${isPrimary ? 'text-xl' : 'text-lg'}`}>
					{title}
				</h3>
				<span class="rounded-full bg-[#e8edf5] px-2 py-1 text-[10px] font-mono tracking-[0.12em] text-[#4b6a96]">
					Live
				</span>
			</div>
			{summary ? (
				<p class={`leading-snug text-[#5c5c54] break-words ${isPrimary ? 'text-base' : 'text-sm'}`}>
					{summary}
				</p>
			) : null}
			<p class="text-[11px] font-mono tracking-[0.08em] text-[#6b6b63]">
				Stack: {techStack.join(' / ')}
			</p>
			<div class="flex items-center gap-4 text-xs font-mono tracking-[0.2em] text-[#6b6b63]">
				<a class="transition hover:text-[#2a2a2a]" href={url} target="_blank" rel="noreferrer">
					Open portal
				</a>
				{repoUrl ? (
					<a class="transition hover:text-[#2a2a2a]" href={repoUrl} target="_blank" rel="noreferrer">
						Repo
					</a>
				) : (
					<span class="text-[#c1c1b8]">Repo</span>
				)}
			</div>
		</div>
	</div>
</article>
