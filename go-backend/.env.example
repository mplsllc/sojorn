# ──────────────────────────────────────────────────────────
# Sojorn Backend — Environment Configuration
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────
PORT=8080
ENV=development                    # development | production
LOG_LEVEL=info                     # debug | info | warn | error
DATABASE_URL=postgres://sojorn:sojorn@localhost:5432/sojorn?sslmode=disable
JWT_SECRET=                        # REQUIRED — generate with: openssl rand -hex 32
CORS_ORIGINS=*                     # Comma-separated list: https://example.com,https://admin.example.com

# ── Instance Identity ────────────────────────────────────
INSTANCE_NAME=Sojorn               # Human-readable name shown in the app
API_BASE_URL=http://localhost:8080  # Public URL of this API
APP_BASE_URL=http://localhost:3000  # Public URL of the frontend/app
COOKIE_DOMAIN=                     # Cookie domain for admin auth (e.g. .example.com). Leave blank for dev.
SUPPORT_EMAIL=                     # Contact email shown to users (e.g. support@example.com)

# ── Email / SMTP ─────────────────────────────────────────
# Required for account verification, password reset, and notifications.
# Leave blank to disable email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                         # Sender address (e.g. noreply@example.com)
SENDER_API_TOKEN=                  # Optional: Sender.net API token (alternative to SMTP)

# ── Cloudflare R2 / S3-Compatible Storage ────────────────
# Required for media uploads (images, videos, audio).
R2_ENDPOINT=                       # e.g. https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_MEDIA_BUCKET=media              # Bucket name for images/audio
R2_VIDEO_BUCKET=videos             # Bucket name for video content
R2_IMG_DOMAIN=                     # CDN domain for images (e.g. img.example.com)
R2_VID_DOMAIN=                     # CDN domain for videos (e.g. vid.example.com)
R2_PUBLIC_BASE_URL=                # Public base URL for media (e.g. https://img.example.com)
R2_SIGNING_SECRET=                 # Secret for signed media URLs

# ── Firebase (Optional — Push Notifications) ─────────────
# Leave blank to disable push notifications.
FIREBASE_CREDENTIALS_FILE=         # Path to Firebase service account JSON

# ── AI / Content Moderation (Optional) ───────────────────
AI_GATEWAY_URL=                    # Local AI gateway URL (e.g. http://localhost:8099)
AI_GATEWAY_TOKEN=                  # Auth token for AI gateway
OLLAMA_URL=http://localhost:11434  # Ollama LLM API URL
SEARXNG_URL=http://localhost:8888  # SearXNG meta-search URL (for official accounts)
SIGHTENGINE_USER=                  # SightEngine API user (image moderation)
SIGHTENGINE_SECRET=                # SightEngine API secret

# ── External Data Sources (Optional) ─────────────────────
ICED_API_BASE=                     # IcedCoffee public-safety API
MN511_PROXY_URL=                   # MN511 traffic data proxy
EVENTBRITE_API_KEY=                # Eventbrite event ingestion
TICKETMASTER_API_KEY=              # Ticketmaster event ingestion

# ── SendPulse (Optional — Newsletter/Waitlist) ───────────
SENDPULSE_ID=
SENDPULSE_SECRET=
